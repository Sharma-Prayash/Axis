<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Reminder & Alarm Permissions -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".ProductivityApp"
        android:allowBackup="true"
        android:icon="@drawable/axis"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ProductivityApp"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.ProductivityApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Boot Receiver — reschedules all alarms after device reboot -->
        <receiver
            android:name=".service.ReminderBootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Alarm Receiver — fires notification when scheduled alarm triggers -->
        <receiver
            android:name=".service.AlarmReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- Morning Digest Receiver — fires morning status/targets digest -->
        <receiver
            android:name=".service.MorningDigestReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- Snooze Receiver — handles snooze action from notification -->
        <receiver
            android:name=".service.SnoozeReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- Done Receiver — handles mark-done action from notification -->
        <receiver
            android:name=".service.DoneReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- Alarm Ring Service — foreground service for alarm sound playback -->
        <service
            android:name=".service.AlarmRingService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Focus Timer Service — foreground service for active focus session ticking -->
        <service
            android:name=".service.FocusTimerService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Ticking study timer to maintain progress in database and show session controls in notification" />
        </service>

    </application>
</manifest>
